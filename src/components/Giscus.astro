---
// Comentarios del blog vía Giscus (sobre GitHub Discussions) — ver _privado/LEGAL.md §1.2.
// Activo desde 2026-07-03: repo público, Discussions activo, app de giscus instalada,
// categoría "Announcements" (recomendación estándar de Giscus para blogs — solo mantenedores
// pueden crear discusiones nuevas, los visitantes solo responden/reaccionan). IDs confirmados
// contra la API de GitHub (discussionCategories), no solo copiados de giscus.app a ciegas.
const REPO = 'arnau-cell/escuela-ia';
const REPO_ID: string = 'R_kgDOTL-UpQ';
const CATEGORY = 'Announcements';
const CATEGORY_ID: string = 'DIC_kwDOTL-Upc4DAcY_';

const { starlightRoute } = Astro.locals;
const locale = starlightRoute.locale === 'en' ? 'en' : 'es';
const enabled = REPO_ID !== '' && CATEGORY_ID !== '';
---

{
	enabled ? (
		<section class="giscus-comments">
			<script
				is:inline
				src="https://giscus.app/client.js"
				data-repo={REPO}
				data-repo-id={REPO_ID}
				data-category={CATEGORY}
				data-category-id={CATEGORY_ID}
				data-mapping="pathname"
				data-strict="1"
				data-reactions-enabled="1"
				data-input-position="top"
				data-theme="preferred_color_scheme"
				data-lang={locale}
				crossorigin="anonymous"
				async
			/>
		</section>
	) : (
		import.meta.env.DEV && (
			<p class="giscus-pending">
				[dev] Giscus no activo todavía: falta habilitar GitHub Discussions y configurar
				REPO_ID/CATEGORY_ID en src/components/Giscus.astro.
			</p>
		)
	)
}

<style>
	.giscus-comments {
		margin-top: 3rem;
	}
	.giscus-pending {
		margin-top: 3rem;
		font-size: var(--sl-text-sm);
		font-style: italic;
		color: var(--sl-color-gray-3);
	}
</style>
