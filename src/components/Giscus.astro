---
// Comentarios del blog vía Giscus (sobre GitHub Discussions) — ver _privado/LEGAL.md §1.2 y
// _privado/protocolo/prompts/E6-constructor.md. PREPARADO, NO ACTIVO: GitHub Discussions sigue
// desactivado en arnau-cell/escuela-ia (`gh api repos/arnau-cell/escuela-ia --jq '.has_discussions'`
// → false, comprobado 2026-07-03). Activarlo es checkpoint humano — requiere ir a GitHub → Settings
// del repo → "Discussions" (casilla), y luego generar repoId/categoryId reales en https://giscus.app
// (pegando el repo y eligiendo la categoría de Discussions a usar, recomendado "Announcements" o una
// categoría nueva "Comentarios blog"). Mientras REPO_ID/CATEGORY_ID estén vacíos, este componente no
// renderiza nada (no se manda ningún script roto a producción).
const REPO = 'arnau-cell/escuela-ia';
const REPO_ID = ''; // TODO(Arnau): pegar aquí el "data-repo-id" que da giscus.app tras activar Discussions
const CATEGORY = 'Comments'; // Ajustar si se crea una categoría de Discussions específica para el blog
const CATEGORY_ID = ''; // TODO(Arnau): pegar aquí el "data-category-id" que da giscus.app

const { starlightRoute } = Astro.locals;
const locale = starlightRoute.locale === 'en' ? 'en' : 'es';
const enabled = REPO_ID !== '' && CATEGORY_ID !== '';
---

{
	enabled ? (
		<section class="giscus-comments">
			<script
				is:inline
				src="https://giscus.app/client.js"
				data-repo={REPO}
				data-repo-id={REPO_ID}
				data-category={CATEGORY}
				data-category-id={CATEGORY_ID}
				data-mapping="pathname"
				data-strict="1"
				data-reactions-enabled="1"
				data-input-position="top"
				data-theme="preferred_color_scheme"
				data-lang={locale}
				crossorigin="anonymous"
				async
			/>
		</section>
	) : (
		import.meta.env.DEV && (
			<p class="giscus-pending">
				[dev] Giscus no activo todavía: falta habilitar GitHub Discussions y configurar
				REPO_ID/CATEGORY_ID en src/components/Giscus.astro.
			</p>
		)
	)
}

<style>
	.giscus-comments {
		margin-top: 3rem;
	}
	.giscus-pending {
		margin-top: 3rem;
		font-size: var(--sl-text-sm);
		font-style: italic;
		color: var(--sl-color-gray-3);
	}
</style>
