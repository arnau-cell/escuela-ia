---
// Preguntas sobre la Wiki de la IA — conectado a /api/wiki/ask (Claude Haiku 4.5). Vive dentro de
// Starlight (usa los tokens --sl-color-*), a diferencia del núcleo, que tiene su propia estética.
interface Props {
	locale: 'es' | 'en';
}
const { locale } = Astro.props;

const UI = {
	es: {
		label: 'Pregunta lo que quieras sobre la Wiki',
		placeholder: '¿Qué diferencia hay entre un agente y un MCP?',
		send: 'Preguntar',
		thinking: 'Buscando la respuesta...',
		notice: 'Respuesta generada por una IA (Claude Haiku) a partir del contenido de esta Wiki, no por una persona.',
		errorGeneric: 'Algo falló. Inténtalo de nuevo.',
	},
	en: {
		label: 'Ask anything about the Wiki',
		placeholder: "What's the difference between an agent and an MCP?",
		send: 'Ask',
		thinking: 'Finding the answer...',
		notice: 'Answer generated by an AI (Claude Haiku) from this Wiki\'s content, not by a person.',
		errorGeneric: 'Something failed. Please try again.',
	},
};
const t = UI[locale];
---

<div class="wiki-ask" data-locale={locale}>
	<label for="wiki-ask-input">{t.label}</label>
	<div class="wiki-ask-row">
		<input id="wiki-ask-input" type="text" placeholder={t.placeholder} />
		<button id="wiki-ask-send" type="button">{t.send}</button>
	</div>
	<p class="wiki-ask-answer" id="wiki-ask-answer" hidden></p>
</div>

<script type="application/json" id="wiki-ask-ui" is:inline set:html={JSON.stringify(t)} />

<script type="module" is:inline>
	const ui = JSON.parse(document.getElementById('wiki-ask-ui').textContent);
	const root = document.querySelector('.wiki-ask');
	const locale = root.dataset.locale === 'en' ? 'en' : 'es';
	const input = document.getElementById('wiki-ask-input');
	const sendBtn = document.getElementById('wiki-ask-send');
	const answerEl = document.getElementById('wiki-ask-answer');

	async function ask() {
		const question = input.value.trim();
		if (!question) return;
		sendBtn.disabled = true;
		answerEl.hidden = false;
		answerEl.textContent = ui.thinking;

		try {
			const res = await fetch('/api/wiki/ask', {
				method: 'POST',
				headers: { 'content-type': 'application/json' },
				body: JSON.stringify({ question, locale }),
			});
			const data = await res.json();
			answerEl.textContent = res.ok ? `${data.answer}\n\n— ${ui.notice}` : (data.error ?? ui.errorGeneric);
		} catch (err) {
			answerEl.textContent = ui.errorGeneric;
		} finally {
			sendBtn.disabled = false;
		}
	}

	sendBtn.addEventListener('click', ask);
	input.addEventListener('keydown', (e) => {
		if (e.key === 'Enter') ask();
	});
</script>

<style>
	.wiki-ask {
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 0.5rem;
		padding: 1.25rem;
		margin-block: 2rem;
		display: grid;
		gap: 0.75rem;
	}
	.wiki-ask label {
		font-weight: 600;
	}
	.wiki-ask-row {
		display: flex;
		gap: 0.5rem;
	}
	#wiki-ask-input {
		flex: 1;
		padding: 0.5rem 0.75rem;
		border-radius: 0.25rem;
		border: 1px solid var(--sl-color-gray-5);
		background: var(--sl-color-bg);
		color: var(--sl-color-text);
	}
	#wiki-ask-send {
		padding: 0.5rem 1.25rem;
		border-radius: 0.25rem;
		border: none;
		background: var(--sl-color-accent);
		color: var(--sl-color-text-invert);
		font-weight: 600;
		cursor: pointer;
	}
	#wiki-ask-send:disabled {
		opacity: 0.6;
		cursor: default;
	}
	.wiki-ask-answer {
		white-space: pre-wrap;
		font-size: var(--sl-text-sm);
		color: var(--sl-color-gray-2);
		border-top: 1px solid var(--sl-color-gray-5);
		padding-top: 0.75rem;
		margin: 0;
	}
</style>
