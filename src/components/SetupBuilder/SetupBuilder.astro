---
// Isla ligera del configurador "Monta tu setup". Determinista, sin IA en runtime: la lógica
// vive en setup-engine.js (función pura), los datos en src/data/setup/*.json. Este componente
// solo pinta el formulario y, en el cliente, llama a recommend()/resolveRoute() con los datos
// ya embebidos en la página (sin llamadas de red).
import { getCollection } from 'astro:content';
import { GOALS, PREFERENCES, LEVELS } from './setup-engine.js';

const { starlightRoute } = Astro.locals;
const locale = starlightRoute.locale === 'en' ? 'en' : 'es';

type BilingualLabel = { es: string; en: string };

const GOAL_LABELS: Record<string, BilingualLabel> = {
	chat_asistente: { es: 'Chat / asistente general', en: 'Chat / general assistant' },
	programar: { es: 'Programar', en: 'Coding' },
	imagenes: { es: 'Generar imágenes', en: 'Generate images' },
	documentos: { es: 'Chatear con mis documentos', en: 'Chat with my documents' },
	automatizar: { es: 'Automatizar tareas (agentes)', en: 'Automate tasks (agents)' },
};
const PREFERENCE_LABELS: Record<string, BilingualLabel> = {
	local: { es: 'Prefiero local (privacidad, sin coste por uso)', en: 'I prefer local (privacy, no per-use cost)' },
	nube: { es: 'Prefiero la nube (sin instalar nada)', en: 'I prefer the cloud (nothing to install)' },
	mixto: { es: 'Me da igual / lo que mejor encaje', en: "I don't mind / whatever fits best" },
};
const LEVEL_LABELS: Record<string, BilingualLabel> = {
	principiante: { es: 'Principiante (Nivel 0)', en: 'Beginner (Level 0)' },
	usuario: { es: 'Usuario habitual (Nivel 1)', en: 'Regular user (Level 1)' },
	constructor: { es: 'Constructor (Nivel 2)', en: 'Builder (Level 2)' },
	tecnico: { es: 'Técnico (Nivel 3)', en: 'Technical (Level 3)' },
};

const UI = {
	es: {
		goal: '¿Qué quieres hacer?',
		preference: 'Local o nube',
		hasGpu: 'Tengo una tarjeta gráfica (GPU) dedicada',
		vram: 'VRAM de tu GPU (GB) — déjalo en 0 si no lo sabes o no tienes GPU',
		budget: 'Presupuesto mensual (USD) — 0 si solo quieres gratis',
		level: 'Tu nivel',
		submit: 'Ver mi ruta',
		resultTitle: 'Tu ruta recomendada',
		steps: 'Pasos',
		alternatives: 'Alternativas',
		cost: 'Coste',
		concepts: 'Para entender esto:',
		fallbackNote:
			'Esta es una recomendación genérica: no encontramos una ruta específica para tu combinación exacta de respuestas.',
	},
	en: {
		goal: 'What do you want to do?',
		preference: 'Local or cloud',
		hasGpu: 'I have a dedicated graphics card (GPU)',
		vram: 'Your GPU VRAM (GB) — leave at 0 if you don\'t know or have no GPU',
		budget: 'Monthly budget (USD) — 0 if you only want free',
		level: 'Your level',
		submit: 'See my route',
		resultTitle: 'Your recommended route',
		steps: 'Steps',
		alternatives: 'Alternatives',
		cost: 'Cost',
		concepts: 'To understand this:',
		fallbackNote: "This is a generic recommendation: we couldn't find a specific route for your exact combination of answers.",
	},
};
const ui = UI[locale];

// Mapa slug-de-concepto → URL real por idioma, para que el script cliente pueda enlazar a
// los conceptos transversales sin necesitar acceso server-side a astro:content.
const allDocs = await getCollection('docs');
const conceptHrefMap: Record<string, { es?: string; en?: string }> = {};
for (const doc of allDocs) {
	if (!doc.data.translationKey.startsWith('aprende/conceptos/')) continue;
	if (doc.data.translationKey === 'aprende/conceptos/index') continue;
	const slug = doc.data.translationKey.replace('aprende/conceptos/', '');
	const isEn = doc.id.startsWith('en/');
	const href = `/${doc.id}/`.replace(/\/+/g, '/');
	conceptHrefMap[slug] = { ...(conceptHrefMap[slug] ?? {}), [isEn ? 'en' : 'es']: href };
}
---

<div class="setup-builder" data-locale={locale}>
	<form id="setup-form" class="setup-form">
		<label>
			<span>{ui.goal}</span>
			<select name="goal" required>
				{GOALS.map((g) => <option value={g}>{GOAL_LABELS[g][locale]}</option>)}
			</select>
		</label>

		<fieldset>
			<legend>{ui.preference}</legend>
			{PREFERENCES.map((p, i) => (
				<label class="radio-label">
					<input type="radio" name="preference" value={p} checked={i === 2} />
					{PREFERENCE_LABELS[p][locale]}
				</label>
			))}
		</fieldset>

		<label class="checkbox-label">
			<input type="checkbox" name="hasGpu" />
			{ui.hasGpu}
		</label>

		<label>
			<span>{ui.vram}</span>
			<input type="number" name="vramGb" min="0" max="256" value="0" />
		</label>

		<label>
			<span>{ui.budget}</span>
			<input type="number" name="budgetMonthly" min="0" max="1000" value="0" />
		</label>

		<label>
			<span>{ui.level}</span>
			<select name="level" required>
				{LEVELS.map((l) => <option value={l}>{LEVEL_LABELS[l][locale]}</option>)}
			</select>
		</label>

		<button type="submit">{ui.submit}</button>
	</form>

	<div id="setup-result" class="setup-result" aria-live="polite"></div>
</div>

<script type="application/json" id="setup-concept-map" is:inline set:html={JSON.stringify(conceptHrefMap)} />

<script type="module">
	import { recommend, resolveRoute } from './setup-engine.js';
	import rulesEs from '../../data/setup/rules.es.json';
	import rulesEn from '../../data/setup/rules.en.json';
	import platforms from '../../data/setup/platforms.json';

	const root = document.querySelector('.setup-builder');
	const locale = root.dataset.locale === 'en' ? 'en' : 'es';
	const rules = locale === 'en' ? rulesEn : rulesEs;
	const conceptHrefMap = JSON.parse(document.getElementById('setup-concept-map').textContent);

	const UI = {
		es: { steps: 'Pasos', alternatives: 'Alternativas', cost: 'Coste', concepts: 'Para entender esto:', resultTitle: 'Tu ruta recomendada', fallbackNote: 'Esta es una recomendación genérica: no encontramos una ruta específica para tu combinación exacta de respuestas.' },
		en: { steps: 'Steps', alternatives: 'Alternatives', cost: 'Cost', concepts: 'To understand this:', resultTitle: 'Your recommended route', fallbackNote: "This is a generic recommendation: we couldn't find a specific route for your exact combination of answers." },
	}[locale];

	const form = document.getElementById('setup-form');
	const resultEl = document.getElementById('setup-result');

	function conceptLink(slug) {
		const href = conceptHrefMap[slug]?.[locale];
		if (!href) return '';
		return href;
	}

	function renderRoute(route) {
		const isFallback = route.id === 'fallback-generico';
		const stepsHtml = route.steps
			.map((step) => {
				const concepts = step.conceptSlugs
					.map((slug) => {
						const href = conceptLink(slug);
						return href ? `<a href="${href}">${slug.replace(/-/g, ' ')}</a>` : '';
					})
					.filter(Boolean)
					.join(', ');
				return `<li>
					<strong><a href="${step.platform?.url ?? '#'}" target="_blank" rel="noopener">${step.platform?.name ?? step.platformId}</a></strong>
					<p>${step.why}</p>
					<p class="setup-cost">${UI.cost}: ${step.platform?.costDetail?.[locale] ?? ''}</p>
					${concepts ? `<p class="setup-concepts">${UI.concepts} ${concepts}</p>` : ''}
				</li>`;
			})
			.join('');

		const altHtml = route.alternatives
			.map((alt) => `<li><a href="${alt.url}" target="_blank" rel="noopener">${alt.name}</a> — ${alt.costDetail?.[locale] ?? ''}</li>`)
			.join('');

		resultEl.innerHTML = `
			<h3>${UI.resultTitle}: ${route.title}</h3>
			${isFallback ? `<p class="setup-fallback-note">${UI.fallbackNote}</p>` : ''}
			<p>${route.summary}</p>
			<h4>${UI.steps}</h4>
			<ol class="setup-steps">${stepsHtml}</ol>
			${altHtml ? `<h4>${UI.alternatives}</h4><ul class="setup-alternatives">${altHtml}</ul>` : ''}
		`;
		resultEl.setAttribute('tabindex', '-1');
		resultEl.focus();
	}

	form.addEventListener('submit', (event) => {
		event.preventDefault();
		const data = new FormData(form);
		const inputs = {
			goal: data.get('goal'),
			preference: data.get('preference'),
			hasGpu: data.get('hasGpu') === 'on',
			vramGb: Number(data.get('vramGb')) || 0,
			budgetMonthly: Number(data.get('budgetMonthly')) || 0,
			level: data.get('level'),
		};
		const rule = recommend(inputs, rules);
		const route = resolveRoute(rule, platforms);
		renderRoute(route);
	});
</script>

<style>
	.setup-builder {
		display: grid;
		gap: 2rem;
		margin-block: 2rem;
	}
	.setup-form {
		display: grid;
		gap: 1rem;
		max-width: 32rem;
	}
	.setup-form label {
		display: grid;
		gap: 0.25rem;
	}
	.setup-form fieldset {
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 0.25rem;
		padding: 0.75rem;
	}
	.radio-label,
	.checkbox-label {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-weight: normal;
	}
	.setup-form select,
	.setup-form input[type='number'] {
		padding: 0.4rem;
		border-radius: 0.25rem;
		border: 1px solid var(--sl-color-gray-5);
		background: var(--sl-color-bg);
		color: var(--sl-color-text);
	}
	.setup-form button {
		justify-self: start;
		padding: 0.6rem 1.5rem;
		border-radius: 0.25rem;
		border: none;
		background: var(--sl-color-accent);
		color: var(--sl-color-white);
		font-weight: 600;
		cursor: pointer;
	}
	.setup-result:empty {
		display: none;
	}
	.setup-result {
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 0.5rem;
		padding: 1.5rem;
	}
	.setup-fallback-note {
		font-style: italic;
		color: var(--sl-color-gray-3);
	}
	.setup-steps li {
		margin-block-end: 1rem;
	}
	.setup-cost,
	.setup-concepts {
		font-size: var(--sl-text-sm);
		color: var(--sl-color-gray-3);
	}
</style>
