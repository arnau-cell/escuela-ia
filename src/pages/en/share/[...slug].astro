---
// Blog post detail page (EN). The `blog` collection doesn't use Starlight's docsLoader (it has
// its own schema, see content.config.ts) so it generates no routes on its own — StarlightPage
// reuses Starlight's layout/theme for a "manual" page.
import { getCollection, render } from 'astro:content';
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import Giscus from '../../../components/Giscus.astro';

export async function getStaticPaths() {
	const entries = await getCollection('blog', (entry) => entry.id.startsWith('en/'));
	return entries.map((entry) => ({
		params: { slug: entry.id.replace(/^en\//, '') },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

const CATEGORY_LABELS: Record<string, string> = {
	reviews: 'Reviews',
	'como-lo-hice': 'How I built it',
	aprendizajes: 'Lessons learned',
};

const dateFormatter = new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' });
---

<StarlightPage
	frontmatter={{
		title: entry.data.title,
		description: entry.data.description,
		translationKey: entry.data.translationKey,
		sourceUpdated: entry.data.sourceUpdated,
		translationOutdated: entry.data.translationOutdated,
	}}
	headings={headings}
>
	<p class="blog-meta">
		<span class="blog-category">{CATEGORY_LABELS[entry.data.category] ?? entry.data.category}</span>
		<span aria-hidden="true">·</span>
		<time datetime={entry.data.publishedAt.toISOString()}>{dateFormatter.format(entry.data.publishedAt)}</time>
		<span aria-hidden="true">·</span>
		<span>{entry.data.author}</span>
	</p>
	{
		entry.data.draft && (
			<aside role="note" class="blog-draft">
				<p>🚧 Draft — not linked yet from the public Share listing.</p>
			</aside>
		)
	}
	<Content />
	<Giscus />
</StarlightPage>

<style>
	.blog-meta {
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
		font-size: var(--sl-text-sm);
		color: var(--sl-color-gray-3);
		margin-bottom: 1.5rem;
	}
	.blog-category {
		font-weight: 600;
		color: var(--sl-color-text-accent);
	}
	.blog-draft {
		border: 1px solid var(--sl-color-orange);
		background-color: var(--sl-color-orange-low);
		padding: 0.75rem 1rem;
		border-radius: 0.25rem;
		margin-block: 1rem;
		font-size: var(--sl-text-sm);
	}
	.blog-draft p {
		margin: 0;
	}
</style>
